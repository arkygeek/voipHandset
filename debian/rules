#!/usr/bin/make -f

export PYBUILD_NAME=voiphandset
export DH_VERBOSE=1

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	# Install conf files into the staging dir
	install -D -m 0644 conf/99-hp-handset.rules \
	    debian/voiphandset/lib/udev/rules.d/99-hp-handset.rules
	install -D -m 0644 conf/60-handset-speakerphone.conf \
	    debian/voiphandset/usr/share/pipewire/pipewire.conf.d/60-handset-speakerphone.conf
	install -D -m 0644 conf/handset-daemon.service \
	    debian/voiphandset/usr/lib/systemd/user/handset-daemon.service
